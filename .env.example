# Copy to backend/.env and fill in your values

API_FOOTBALL_KEY=your_api_sports_key_here
DB_URL=sqlite+aiosqlite:///./sisibet.db
BACKEND_PORT=8010
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Scheduler: comma-separated HH:MM times (UTC)
SYNC_TIMES=06:00,10:00,14:00,18:00,23:30

# Bayesian thresholds
MIN_VALUE_EDGE=0.05
MIN_DERIVED_PROB=0.50
HIGH_CONF_EDGE=0.07
HIGH_CONF_PROB=0.60
