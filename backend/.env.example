API_FOOTBALL_KEY=your_api_sports_io_key_here
# Protect all /api/* routes. Set a strong random string in production.
# Leave empty to disable auth (fine for localhost-only dev).
API_KEY=
# Groq AI advisor (free) — get key at console.groq.com. Leave empty to disable AI advisors.
GROQ_API_KEY=
DB_URL=sqlite+aiosqlite:///./sisibet.db
BACKEND_PORT=8010
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Scheduler sync times (comma-separated HH:MM UTC)
SYNC_TIMES=04:00,18:00,22:05

# Dual engine thresholds
MIN_VALUE_EDGE=0.05
MIN_DERIVED_PROB=0.50
MIN_ODDS=1.50
MIN_EDGE_PCT=5.0
KELLY_FRACTION=0.25
MAX_KELLY_PCT=0.05
UNIT_PCT=0.01
DEFAULT_BANKROLL=100.0
